  "settings": {
    "deviationsAlwaysDocumented": true,
    "requireActorIdentity": true,
    "requireObservedAt": true,
    "requireCorrectiveActionBeforeClosure": true,
    "allowSilentDeletionOfCompletedControls": false,
    "allowSilentOverwriteOfCompletedControls": false
  },
  "productTemperatureProfiles": [
    {
      "id": "chilled-general-draft",
      "label": "Køl – generelt startforslag",
      "status": "requires_review",
      "acceptance": { "operator": "lte", "value": 5, "unit": "celsius" },
      "notes": "Må ikke bruges ukritisk til alle varer. Nogle produkter har strengere krav, og for andre fastsætter virksomheden selv en temperatur ud fra produkt, holdbarhed og salgsform.",
      "sourceRefs": ["fvst-cold-storage", "fvst-written-controls"]
    },
    {
      "id": "chilled-strict-placeholder",
      "label": "Køl – produkt med strengere krav",
      "status": "requires_product_mapping",
      "acceptance": { "operator": "lte", "value": 2, "unit": "celsius" },
      "notes": "Eksempelprofil fra Fødevarestyrelsens egenkontrolmateriale. Tilknyt kun konkrete produktkategorier efter faglig afklaring.",
      "sourceRefs": ["fvst-written-controls"]
    },
    {
      "id": "deep-frozen-draft",
      "label": "Dybfrost – startforslag",
      "status": "requires_review",
      "acceptance": { "operator": "lte", "value": -18, "unit": "celsius" },
      "notes": "Kontrollér produktkategori, mærkning og eventuelle tolerancer før aktivering.",
      "sourceRefs": ["fvst-written-controls"]
