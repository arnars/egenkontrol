  "controls": [
    {
      "id": "receiving-check",
      "revision": 1,
      "status": "draft_requires_approval",
      "title": "Kontrol ved varemodtagelse",
      "activityId": "goods-receiving",
      "description": "Kontrollér relevante leverancer før varerne tages i brug.",
      "controlFrequency": { "kind": "per_event", "eventType": "delivery" },
      "documentationFrequency": { "kind": "weekly", "targetCount": 1, "deviationsAlways": true },
      "fields": [
        { "id": "supplier", "type": "text", "label": "Leverandør", "required": true },
        { "id": "product", "type": "text", "label": "Vare", "required": true },
        { "id": "temperatureProfileId", "type": "temperature_profile", "label": "Temperaturprofil", "required": false },
        { "id": "measuredTemperature", "type": "temperature", "label": "Målt temperatur", "unit": "celsius", "requiredWhen": "temperatureProfileId is set" },
        { "id": "packagingIntact", "type": "yes_no", "label": "Emballage er intakt", "expected": true, "required": true },
        { "id": "labelAndDateAcceptable", "type": "yes_no", "label": "Mærkning og dato er acceptable", "expected": true, "required": true }
      ],
      "deviationTriggers": ["temperature_outside_selected_profile", "packagingIntact == false", "labelAndDateAcceptable == false"],
      "correctiveActionPrompts": ["Afvis eller returnér varen", "Vurdér og dokumentér om varen kan anvendes straks", "Kassér varen", "Kontakt leverandøren", "Anden dokumenteret handling"],
      "sourceRefs": ["fvst-receiving", "fvst-written-controls"]
    },
    {
      "id": "refrigeration-temperature",
      "revision": 1,
      "status": "draft_requires_approval",
      "title": "Temperatur på køl",
      "activityId": "cold-storage",
      "description": "Kontrollér relevante køleenheder og den produktprofil, der gælder for deres indhold.",
      "controlFrequency": { "kind": "daily", "localTime": "09:00" },
      "documentationFrequency": { "kind": "every_control", "deviationsAlways": true },
      "fields": [
        { "id": "unitId", "type": "asset_reference", "label": "Køleenhed", "required": true },
        { "id": "temperatureProfileId", "type": "temperature_profile", "label": "Temperaturprofil", "required": true, "defaultValue": "chilled-general-draft" },
        { "id": "measuredTemperature", "type": "temperature", "label": "Målt temperatur", "unit": "celsius", "required": true }
      ],
      "deviationTriggers": ["temperature_outside_selected_profile"],
      "correctiveActionPrompts": ["Kontrollér med en retvisende produktmåling", "Flyt berørte varer til egnet køl", "Vurdér og dokumentér varernes sikkerhed", "Tilkald service", "Anden dokumenteret handling"],
      "sourceRefs": ["fvst-cold-storage", "fvst-written-controls"]
    },
    {
      "id": "freezer-temperature",
      "revision": 1,
      "status": "draft_requires_approval",
      "title": "Temperatur på frost",
      "activityId": "frozen-storage",
      "description": "Kontrollér fryseenheder og de produktkrav, der gælder for deres indhold.",
      "controlFrequency": { "kind": "daily", "localTime": "09:00" },
      "documentationFrequency": { "kind": "every_control", "deviationsAlways": true },
      "fields": [
        { "id": "unitId", "type": "asset_reference", "label": "Fryseenhed", "required": true },
        { "id": "temperatureProfileId", "type": "temperature_profile", "label": "Temperaturprofil", "required": true, "defaultValue": "deep-frozen-draft" },
        { "id": "measuredTemperature", "type": "temperature", "label": "Målt temperatur", "unit": "celsius", "required": true }
      ],
      "deviationTriggers": ["temperature_outside_selected_profile"],
      "correctiveActionPrompts": ["Kontrollér med en retvisende produktmåling", "Flyt berørte varer til egnet frost", "Vurdér og dokumentér varernes sikkerhed", "Tilkald service", "Anden dokumenteret handling"],
      "sourceRefs": ["fvst-written-controls"]
    },
    {
      "id": "heating-core-temperature",
      "revision": 1,
      "status": "draft_requires_approval",
      "title": "Opvarmning",
      "activityId": "heat-treatment",
      "description": "Mål kernetemperaturen for den valgte produkt-/procesprofil.",
      "controlFrequency": { "kind": "per_event", "eventType": "heating_batch" },
      "documentationFrequency": { "kind": "weekly", "targetCount": 1, "selectionRule": "one_relevant_occurrence_when_activity_occurs; otherwise_not_relevant", "deviationsAlways": true },
      "fields": [
        { "id": "productOrBatch", "type": "text", "label": "Produkt eller batch", "required": true },
        { "id": "measuredCoreTemperature", "type": "temperature", "label": "Målt kernetemperatur", "unit": "celsius", "required": true },
        { "id": "minimumCoreTemperature", "type": "temperature_limit", "label": "Godkendt minimum", "unit": "celsius", "required": true, "defaultValue": 75, "editable": true }
      ],
      "deviationTriggers": ["measuredCoreTemperature < minimumCoreTemperature"],
      "correctiveActionPrompts": ["Fortsæt varmebehandlingen og mål igen", "Vurdér alternativ valideret tid-/temperaturproces", "Kassér produktet", "Anden dokumenteret handling"],
      "notes": "75 °C er et almindeligt officielt eksempel, men der findes produkter og validerede processer, hvor andre kombinationer gælder. Profilen skal tilpasses den konkrete risikoanalyse.",
      "sourceRefs": ["fvst-written-controls", "fvst-heat-treatment"]
    },
    {
      "id": "cooling-time-temperature",
      "revision": 1,
      "status": "draft_requires_approval",
      "title": "Nedkøling",
      "activityId": "cooling",
      "description": "Dokumentér start- og slutmåling for en nedkølingsbatch.",
      "controlFrequency": { "kind": "per_event", "eventType": "cooling_batch" },
      "documentationFrequency": { "kind": "weekly", "targetCount": 1, "selectionRule": "one_relevant_occurrence_when_activity_occurs; otherwise_not_relevant", "deviationsAlways": true },
      "fields": [
        { "id": "product", "type": "text", "label": "Ret", "required": true },
        { "id": "batchDate", "type": "date", "label": "Batchdato", "required": true, "defaultValue": "today" },
        { "id": "startTemperature", "type": "temperature", "label": "Starttemperatur", "unit": "celsius", "required": true },
        { "id": "startTime", "type": "datetime", "label": "Starttid", "required": true },
        { "id": "endTemperature", "type": "temperature", "label": "Sluttemperatur", "unit": "celsius", "required": true },
        { "id": "endTime", "type": "datetime", "label": "Sluttid", "required": true }
      ],
      "limit": {
        "kind": "cooling_curve",
        "fromTemperature": 56,
        "toTemperature": 10,
        "maximumDurationMinutes": 240,
        "editable": true
      },
      "deviationTriggers": ["cooling_curve_not_met"],
      "correctiveActionPrompts": ["Fortsæt hurtig nedkøling og mål igen efter faglig vurdering", "Fordel produktet i mindre portioner eller brug egnet udstyr", "Vurdér og dokumentér produktets sikkerhed", "Kassér produktet", "Anden dokumenteret handling"],
      "notes": "Andre dokumenterede tid-/temperaturkombinationer kan give samme sikkerhed. Ændringer kræver fagligt grundlag.",
      "sourceRefs": ["fvst-cooling", "fvst-written-controls"]
    },
    {
      "id": "hot-holding-temperature",
      "revision": 1,
      "status": "draft_requires_approval",
      "title": "Varmholdelse",
      "activityId": "hot-holding",
      "description": "Kontrollér temperaturen på varmholdte fødevarer.",
      "controlFrequency": { "kind": "per_event", "eventType": "hot_holding_service" },
      "documentationFrequency": { "kind": "weekly", "targetCount": 1, "selectionRule": "one_relevant_occurrence_when_activity_occurs; otherwise_not_relevant", "deviationsAlways": true },
      "fields": [
        { "id": "productOrBatch", "type": "text", "label": "Produkt eller batch", "required": true },
        { "id": "measuredTemperature", "type": "temperature", "label": "Målt temperatur", "unit": "celsius", "required": true },
        { "id": "minimumTemperature", "type": "temperature_limit", "label": "Godkendt minimum", "unit": "celsius", "required": true, "defaultValue": 56, "editable": true }
      ],
      "deviationTriggers": ["measuredTemperature < minimumTemperature"],
      "correctiveActionPrompts": ["Genopvarm efter godkendt procedure og mål igen", "Vurdér og dokumentér produktets sikkerhed", "Kassér produktet", "Anden dokumenteret handling"],
      "sourceRefs": ["fvst-heat-treatment"]
    }
  ]
}
