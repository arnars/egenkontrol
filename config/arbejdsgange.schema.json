{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/arnars/egenkontrol/blob/main/config/arbejdsgange.schema.json",
  "title": "Katalog over arbejdsgange og tværgående procedurer",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "catalogVersion", "status", "disclaimer", "sourceRegistry", "practiceAreas"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "catalogVersion": { "type": "string", "minLength": 1 },
    "status": { "enum": ["draft_requires_business_approval", "approved", "retired"] },
    "disclaimer": { "type": "string", "minLength": 1 },
    "sourceRegistry": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["title", "url", "reviewedAt"],
        "properties": {
          "title": { "type": "string", "minLength": 1 },
          "url": { "type": "string", "format": "uri" },
          "reviewedAt": { "type": "string", "format": "date" }
        }
      }
    },
    "practiceAreas": {
      "type": "array",
      "items": { "$ref": "#/$defs/practiceArea" }
    }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
    "practiceArea": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "category", "enabledByDefault", "status", "purpose", "suggestedRoutine", "normalDocumentation", "alwaysRecord", "reviewTriggers", "sourceRefs"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "label": { "type": "string", "minLength": 1 },
        "category": { "enum": ["good_working_practice_candidate", "risk_control_candidate", "documented_procedure_candidate"] },
        "enabledByDefault": { "type": "boolean" },
        "status": { "enum": ["requires_review", "approved", "retired"] },
        "purpose": { "type": "string", "minLength": 1 },
        "suggestedRoutine": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "normalDocumentation": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "suggestion"],
          "properties": {
            "kind": { "enum": ["business_decides", "required_information_and_change_log", "traceability_records", "event_driven"] },
            "suggestion": { "type": "string", "minLength": 1 }
          }
        },
        "alwaysRecord": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "reviewTriggers": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "sourceRefs": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/id" } }
      }
    }
  }
}
