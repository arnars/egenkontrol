{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/arnars/egenkontrol/blob/main/config/egenkontrol.schema.json",
  "title": "Egenkontrolkonfiguration",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "catalogVersion", "status", "locale", "timeZone", "sourceRegistry", "settings", "productTemperatureProfiles", "activities", "controls"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "catalogVersion": { "type": "string", "minLength": 1 },
    "status": { "enum": ["draft_requires_business_approval", "approved", "retired"] },
    "locale": { "type": "string", "minLength": 2 },
    "timeZone": { "type": "string", "minLength": 1 },
    "disclaimer": { "type": "string" },
    "sourceRegistry": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/source" }
    },
    "settings": {
      "type": "object",
      "additionalProperties": false,
      "required": ["deviationsAlwaysDocumented", "requireActorIdentity", "requireObservedAt", "requireCorrectiveActionBeforeClosure", "allowSilentDeletionOfCompletedControls", "allowSilentOverwriteOfCompletedControls"],
      "properties": {
        "deviationsAlwaysDocumented": { "const": true },
        "requireActorIdentity": { "const": true },
        "requireObservedAt": { "const": true },
        "requireCorrectiveActionBeforeClosure": { "const": true },
        "allowSilentDeletionOfCompletedControls": { "const": false },
        "allowSilentOverwriteOfCompletedControls": { "const": false }
      }
    },
    "productTemperatureProfiles": {
      "type": "array",
      "items": { "$ref": "#/$defs/temperatureProfile" }
    },
    "activities": {
      "type": "array",
      "items": { "$ref": "#/$defs/activity" }
    },
    "controls": {
      "type": "array",
      "items": { "$ref": "#/$defs/control" }
    }
  },
  "$defs": {
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "url", "reviewedAt"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "format": "uri" },
        "reviewedAt": { "type": "string", "format": "date" }
      }
    },
    "acceptance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operator", "value", "unit"],
      "properties": {
        "operator": { "enum": ["lt", "lte", "gt", "gte", "between"] },
        "value": { "type": "number" },
        "maximum": { "type": "number" },
        "unit": { "enum": ["celsius"] }
      }
    },
    "temperatureProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "status", "acceptance", "notes", "sourceRefs"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "label": { "type": "string", "minLength": 1 },
        "status": { "enum": ["requires_review", "requires_product_mapping", "approved", "retired"] },
        "acceptance": { "$ref": "#/$defs/acceptance" },
        "notes": { "type": "string" },
        "sourceRefs": { "$ref": "#/$defs/sourceRefs" }
      }
    },
    "activity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "enabled", "sortOrder", "riskCategories", "controlIds"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "label": { "type": "string", "minLength": 1 },
        "enabled": { "type": "boolean" },
        "sortOrder": { "type": "integer" },
        "riskCategories": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "controlIds": { "type": "array", "items": { "$ref": "#/$defs/id" }, "uniqueItems": true }
      }
    },
    "control": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "revision", "status", "title", "activityId", "description", "controlFrequency", "documentationFrequency", "fields", "deviationTriggers", "correctiveActionPrompts", "sourceRefs"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "revision": { "type": "integer", "minimum": 1 },
        "status": { "enum": ["draft_requires_approval", "approved", "retired"] },
        "title": { "type": "string", "minLength": 1 },
        "activityId": { "$ref": "#/$defs/id" },
        "description": { "type": "string", "minLength": 1 },
        "controlFrequency": { "$ref": "#/$defs/controlFrequency" },
        "documentationFrequency": { "$ref": "#/$defs/documentationFrequency" },
        "fields": { "type": "array", "minItems": 1, "items": { "type": "object", "required": ["id", "type", "label"], "additionalProperties": true } },
        "deviationTriggers": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "correctiveActionPrompts": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "sourceRefs": { "$ref": "#/$defs/sourceRefs" }
      }
    },
    "controlFrequency": {
      "oneOf": [
        { "type": "object", "required": ["kind"], "properties": { "kind": { "const": "daily" }, "localTime": { "type": "string" } }, "additionalProperties": false },
        { "type": "object", "required": ["kind", "weekday"], "properties": { "kind": { "const": "weekly" }, "weekday": { "$ref": "#/$defs/weekday" }, "localTime": { "type": "string" } }, "additionalProperties": false },
        { "type": "object", "required": ["kind", "weekdays"], "properties": { "kind": { "const": "selected_weekdays" }, "weekdays": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/weekday" } }, "localTime": { "type": "string" } }, "additionalProperties": false },
        { "type": "object", "required": ["kind", "dayOfMonth"], "properties": { "kind": { "const": "monthly" }, "dayOfMonth": { "type": "integer", "minimum": 1, "maximum": 31 }, "localTime": { "type": "string" } }, "additionalProperties": false },
        { "type": "object", "required": ["kind", "every", "unit"], "properties": { "kind": { "const": "interval" }, "every": { "type": "integer", "minimum": 1 }, "unit": { "enum": ["day", "week", "month"] } }, "additionalProperties": false },
        { "type": "object", "required": ["kind", "eventType"], "properties": { "kind": { "const": "per_event" }, "eventType": { "type": "string", "minLength": 1 } }, "additionalProperties": false },
        { "type": "object", "required": ["kind", "month", "day"], "properties": { "kind": { "const": "yearly" }, "month": { "type": "integer", "minimum": 1, "maximum": 12 }, "day": { "type": "integer", "minimum": 1, "maximum": 31 }, "localTime": { "type": "string" } }, "additionalProperties": false }
      ]
    },
    "weekday": {
      "enum": ["monday", "tuesday", "wednesday", "thursday", "friday", "saturday", "sunday"]
    },
    "documentationFrequency": {
      "type": "object",
      "required": ["kind", "deviationsAlways"],
      "properties": {
        "kind": { "enum": ["every_control", "selected_occurrences", "weekly", "monthly", "deviations_only"] },
        "targetCount": { "type": "integer", "minimum": 1 },
        "selectionRule": { "type": "string" },
        "deviationsAlways": { "const": true }
      },
      "additionalProperties": false
    },
    "sourceRefs": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/id" }, "uniqueItems": true },
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" }
  }
}
