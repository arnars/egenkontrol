# Vercel/serverless runtime: use Supabase transaction pooler (port 6543).
DATABASE_URL=postgres://postgres.PROJECT_REF:PASSWORD@REGION.pooler.supabase.com:6543/postgres

# Drizzle migrations, pg_dump and administration: use the direct connection (port 5432).
DIRECT_URL=postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres

# Public Supabase values. These are safe to expose only together with correct RLS policies.
PUBLIC_SUPABASE_URL=https://PROJECT_REF.supabase.co
PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only and highly privileged. Never expose to browser code.
SUPABASE_SERVICE_ROLE_KEY=

# Read-only local path to the visual reference project.
RECIPE_SITE_PATH=../recipe-site
